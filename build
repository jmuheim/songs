#!/usr/bin/env ruby

require 'optparse'
require 'shellwords'
require 'json'
require 'net/http'
require 'nokogiri'

ENV['LANG'] = 'en_US.UTF-8'
Encoding.default_external = Encoding::UTF_8

Dir.chdir(__dir__)

MULTIPLEX_URL     = 'https://multiplex.up.railway.app'
MASTER_PASSWORD   = ENV.fetch('MASTER_PASSWORD', 'guitar')
MULTIPLEX_TOKEN   = File.exist?('multiplex-token.json') \
  ? JSON.parse(File.read('multiplex-token.json')) \
  : JSON.parse(Net::HTTP.get(URI("#{MULTIPLEX_URL}/token"))).tap { |t| File.write('multiplex-token.json', JSON.generate(t)) }

options = { pdf: false, deploy: false }
OptionParser.new do |opts|
  opts.banner = "Usage: build [options]"
  opts.on("--pdf",    "Generate PDF (slow)")               { options[:pdf]    = true }
  opts.on("--deploy", "Deploy to songs.josh.ch via rsync") { options[:deploy] = true }
end.parse!

def step(emoji, label)
  print "#{emoji}  #{label}... "
  t = Time.now
  result = yield
  puts "✅ (#{"%.1f" % (Time.now - t)}s)"
  result
end

def wrap_slide_content(html)
  doc = Nokogiri::HTML(html)
  doc.css('section[id], section[class]').each do |section|
    children = section.children.to_a
    wrapper = Nokogiri::XML::Node.new('div', doc)
    wrapper['class'] = 'slide-content'
    section.add_child(wrapper)
    children.each { |child| wrapper.add_child(child) }
  end
  doc.to_html
end

def pandoc(output:, theme:)
  result = `pandoc -f markdown+hard_line_breaks -t revealjs -s -o #{output} all-songs.md --slide-level=2 --syntax-highlighting=none --toc --toc-depth=1 -V theme=#{theme} -V progress=false -V revealjs-url=./style/revealjs -V disableLayout=true 2>&1`
  print result unless result.strip.empty?
end

puts "🎸 Building song book"
puts

song_files = Dir["content/songs/*.md"].sort
puts "🎵 Songs (#{song_files.size}):"
song_files.each { |f| puts "   🎶 #{File.basename(f, ".md")}" }
puts


songs_md = song_files.map do |file|
  File.read(file).gsub(/\[([A-Z][^\]]*)\]([^\(])/) { "`#{$1}`{.#{$1[0].downcase}}#{$2}" }
end

step("📝", "Writing all-songs.md") do
  frontmatter = <<~MD
    ---
    title:  Lieblings-Songs 🔥🎶🌛
    author: 😊 Josua & Monika ❤️
    ---
  MD
  parts = [frontmatter, File.read("content/Introduction.md"), *songs_md].map(&:rstrip)
  File.write("all-songs.md", parts.join("\n\n") + "\n")
end

step("🌙", "Generating index.html (Pandoc)") { pandoc(output: "index.html", theme: "night") }

step("✨", "Post-processing index.html") do
  html = File.read("index.html")
  multiplex_config = { url: MULTIPLEX_URL, socketId: MULTIPLEX_TOKEN['socketId'], secret: MULTIPLEX_TOKEN['secret'], password: MASTER_PASSWORD }.to_json
  html.sub!("<body>", "<body><script>window.MULTIPLEX=#{multiplex_config};</script>" + File.read("style/body-controls.html").strip)
  html.sub!("<style>", "<style>" + File.read("style/night.css") + File.read("style/shared.css"))
  html.gsub!(%r{  <script src="./style/revealjs/plugin/(notes|search|zoom)/\1\.js"></script>\n}, "")
  html.sub!("plugins: [\n          RevealNotes,\n          RevealSearch,\n          RevealZoom\n        ]", "plugins: []")
  html.sub!("keyboard: true,", "keyboard: { 83: null }, // 's' disabled (was: speaker notes)")
  html.sub!("controls: true,", "controls: false,")
  html.sub!("display: 'block',", "display: 'flex',")
  html.sub!("</body>", "  <script src=\"#{MULTIPLEX_URL}/socket.io/socket.io.js\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js\"></script>\n  <script src=\"style/slide-zoom.js\"></script>\n</body>")
  html = wrap_slide_content(html)
  File.write("index.html", html)
end

step("🖨️", "Generating print.html (Pandoc)") { pandoc(output: "print.html", theme: "serif") }

step("✨", "Post-processing print.html") do
  html = File.read("print.html")
  html.sub!("<style>", "<style>" + File.read("style/serif.css") + File.read("style/shared.css"))
  html.gsub!(/<section id="resources[-\d]*?" class="slide level2">.*?<\/section>/m, "")
  html.sub!('<section id="title-slide"', '<section id="title-slide" data-background-image="style/background.jpg"')
  html.gsub!(%r{  <script src="./style/revealjs/plugin/(notes|search|zoom)/\1\.js"></script>\n}, "")
  html.sub!("plugins: [\n          RevealNotes,\n          RevealSearch,\n          RevealZoom\n        ]", "plugins: []")
  html = wrap_slide_content(html)
  File.write("print.html", html)
end

if options[:pdf]
  step("📄", "Generating print.pdf (DeckTape)") do
    url = Shellwords.shellescape("file://#{File.expand_path('print.html')}")
    output = `decktape -s 1600x1200 #{url} print.pdf 2>&1`
    print "\n#{output}" unless output.strip.empty?
  end
end

if options[:deploy]
  step("🚀", "Deploying to songs.josh.ch") do
    puts
    system("rsync -avz --delete index.html style maroni@greip.uberspace.de:/var/www/virtual/maroni/songs.josh.ch/")
  end
end

puts
puts "🎉 Done!"
